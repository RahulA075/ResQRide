  "item": [
    {
      "name": "Health & Test",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3001/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["health"]
            }
          }
        },
        {
          "name": "Test Database Connection",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3001/api/test-db",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "test-db"]
            }
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "Get All Drivers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3001/api/drivers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "drivers"]
            }
          }
        },
        {
          "name": "Create Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+91-9876543210\",\n  \"license_number\": \"DL123456789\",\n  \"location\": {\n    \"latitude\": 9.9252,\n    \"longitude\": 78.1198\n  },\n  \"vehicle_info\": {\n    \"make\": \"Toyota\",\n    \"model\": \"Camry\",\n    \"year\": 2020\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/drivers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "drivers"]
            }
          }
        },
        {
          "name": "Find Nearby Drivers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3001/api/drivers/nearby?latitude=9.9252&longitude=78.1198&radius=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "drivers", "nearby"],
              "query": [
                {
                  "key": "latitude",
                  "value": "9.9252"
                },
                {
                  "key": "longitude",
                  "value": "78.1198"
                },
                {
                  "key": "radius",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Update Driver",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"status\": \"busy\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/drivers/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "drivers", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "driver-uuid-here"
                }
              ]
            }
          }
        }
      ]
    },
